FORMULA_RECOGNIZER_MODE=demo

# Vercel demo deployment defaults to demo mode automatically.
# If you want to restore local PaddleOCR recognition, install requirements.ocr.txt
# and then switch the mode back to paddleocr.
# FORMULA_RECOGNIZER_MODE=paddleocr

PADDLE_OCR_DEVICE=cpu
PADDLE_OCR_USE_LAYOUT_DETECTION=false
PADDLE_OCR_USE_DOC_ORIENTATION_CLASSIFY=false
PADDLE_OCR_USE_DOC_UNWARPING=false
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true

HOST=0.0.0.0
PORT=5050
MAX_UPLOAD_MB=5
FLASK_DEBUG=false
TRUST_PROXY=false

# Waitress settings for public serving
WAITRESS_THREADS=8
WAITRESS_CONNECTION_LIMIT=100

# Recommended default for public deployment.
# If you run on a Windows machine with Microsoft Word installed,
# you can change this to true for stronger Word equation compatibility.
WORD_COM_AUTOMATION_ENABLED=false

# In the Vercel demo deployment, Word export is disabled by default.
# Set this to true only if the runtime really has the required conversion dependencies.
# FORMULA_WORD_EXPORT_ENABLED=false

# Optional custom Paddle formula model
# PADDLE_OCR_FORMULA_MODEL_NAME=PP-FormulaNet_plus-M
# PADDLE_OCR_FORMULA_MODEL_DIR=E:\models\PP-FormulaNet_plus-M

# Local-only HTTPS options for Word add-in debugging.
# For public deployment, prefer HTTPS at the reverse proxy layer.
# FORMULA_OCR_SSL_CERT_FILE=certs/localhost-cert.pem
# FORMULA_OCR_SSL_KEY_FILE=certs/localhost-key.pem
# FLASK_SSL_ADHOC=false
